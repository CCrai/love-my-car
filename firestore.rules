rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isBusinessMember(businessId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && businessId in userDoc().data.businesses;
    }

    function isBusinessOwner(businessId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid;
    }

    function validBusinessTypes() {
      return request.resource.data.types is list
        && request.resource.data.types.size() > 0
        && request.resource.data.types.size() <= 5;
    }

    match /users/{userId} {
      // Users can read/update their own profile.
      allow read, update: if isSignedIn() && request.auth.uid == userId;

      // Allow user bootstrap document creation after signup.
      allow create: if isSignedIn() && request.auth.uid == userId;

      // Do not allow profile deletions from client app.
      allow delete: if false;
    }

    match /businesses/{businessId} {
      allow read: if isBusinessMember(businessId);

      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && validBusinessTypes();

      allow update: if isBusinessOwner(businessId)
        && request.resource.data.ownerId == resource.data.ownerId
        && validBusinessTypes();

      allow delete: if false;
    }

    match /employees/{employeeId} {
      allow read: if isSignedIn() && isBusinessMember(resource.data.businessId);

      // Only business owner can add collaborators.
      allow create: if isSignedIn()
        && request.resource.data.businessId is string
        && request.resource.data.userId is string
        && request.resource.data.role in ['owner', 'admin', 'employee']
        && isBusinessOwner(request.resource.data.businessId);

      // Only business owner can change/remove collaborators.
      allow update, delete: if isSignedIn()
        && isBusinessOwner(resource.data.businessId);
    }

    match /services/{serviceId} {
      allow read: if isSignedIn() && isBusinessMember(resource.data.businessId);

      allow create: if isSignedIn()
        && request.resource.data.businessId is string
        && isBusinessMember(request.resource.data.businessId);

      allow update, delete: if isSignedIn()
        && isBusinessMember(resource.data.businessId);
    }

    match /vehicles/{vehicleId} {
      allow read: if isSignedIn() && isBusinessMember(resource.data.businessId);

      allow create: if isSignedIn()
        && request.resource.data.businessId is string
        && isBusinessMember(request.resource.data.businessId);

      allow update, delete: if isSignedIn()
        && isBusinessMember(resource.data.businessId);
    }

    match /visits/{visitId} {
      allow read: if isSignedIn() && isBusinessMember(resource.data.businessId);

      allow create: if isSignedIn()
        && request.resource.data.businessId is string
        && request.resource.data.vehicleId is string
        && request.resource.data.serviceId is string
        && isBusinessMember(request.resource.data.businessId)
        && get(/databases/$(database)/documents/vehicles/$(request.resource.data.vehicleId)).data.businessId == request.resource.data.businessId
        && get(/databases/$(database)/documents/services/$(request.resource.data.serviceId)).data.businessId == request.resource.data.businessId;

      allow update, delete: if isSignedIn()
        && isBusinessMember(resource.data.businessId);
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
